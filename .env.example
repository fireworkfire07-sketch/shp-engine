# SHP Engine environment example
# Copy this file to .env locally. Never commit real secrets.

PROJECT_NAME=shp-engine
YOUTUBE_PRIVACY_STATUS=private
OUTPUT_DIR=output

# Optional API keys. Keep real values only in Vercel/GitHub secrets/local .env.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
